# =============================================================================
# tirgus.izipizi.lv — production environment variables
# =============================================================================
# Copy values into Vercel: Project Settings → Environment Variables → Production
# DO NOT commit the filled version. Keep secrets in Vercel only.
#
# Last updated: 2026-04-29
# =============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...                # public, safe in browser
SUPABASE_SECRET_KEY=eyJhbGciOi...                          # service_role — SERVER ONLY

# ─── Public site URL ─────────────────────────────────────────────────────────
# Used by Paysera (accept/cancel/callback URLs), email links, OG tags.
NEXT_PUBLIC_SITE_URL=https://tirgus.izipizi.lv

# ─── Paysera ─────────────────────────────────────────────────────────────────
# Modes:
#   live  — real money, real customers
#   test  — Paysera sandbox (test=1 param), no real money
#   mock  — skip Paysera entirely, jump straight to /cart/success (E2E tests)
PAYSERA_MODE=live
PAYSERA_PROJECT_ID=256875                                  # SIA Svaigi → tirgus.izipizi.lv (Vercel)
PAYSERA_SIGN_PASSWORD=                                     # secret signing password — Paysera panel → Project → Settings

# ─── Esteria SMS ─────────────────────────────────────────────────────────────
# Buyer SMS (locker codes, order updates). 160 chars, no LV diacritics.
# Send: https://api.esteria.eu/send
ESTERIA_API_KEY=
ESTERIA_SENDER=IziPiziAPP                                  # max 11 chars, alphanumeric

# ─── Resend (transactional email) ────────────────────────────────────────────
# https://resend.com → API Keys
# Verify domain "izipizi.lv" first (DNS TXT + DKIM)
RESEND_API_KEY=re_...
EMAIL_FROM="tirgus.izipizi.lv <noreply@izipizi.lv>"
EMAIL_REPLY_TO=info@izipizi.lv                             # optional

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dzenis.rolands@gmail.com

# ─── Cron (Vercel scheduled) ─────────────────────────────────────────────────
# Random string, 32+ chars. Sent as Authorization header by Vercel cron.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── IziPizi Locker API (post-launch) ────────────────────────────────────────
# Leave empty until provisioned. Manual workflow used for now.
# IZIPIZI_API_URL=
# IZIPIZI_API_KEY=
