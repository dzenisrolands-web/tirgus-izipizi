# Copy to .env.local and fill in values

# Supabase
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   ← Supabase > Settings > API > service_role

# Push notifications — generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Cron (generate any random string, add to Vercel env vars too)
# CRON_SECRET=

# Paysera
# Mode: live / test / mock (mock = skip Paysera, redirect straight to success — for E2E tests)
# PAYSERA_MODE=test
# PAYSERA_PROJECT_ID=
# PAYSERA_SIGN_PASSWORD=

# Public site URL (used in Paysera accept/cancel/callback URLs; falls back to request host)
# NEXT_PUBLIC_SITE_URL=https://tirgus.izipizi.lv

# Esteria SMS (lieto izipizi.lv pasūtījumu paziņojumiem)
# Send: https://api.esteria.eu/send · Status: https://api1.esteria.lv/status-xml
# Limits: 160 chars, no Latvian diacritics (auto-transliterated)
# ESTERIA_API_KEY=
# ESTERIA_SENDER=IziPiziAPP

# izipizi Locker API (add later)
# IZIPIZI_API_URL=
# IZIPIZI_API_KEY=
